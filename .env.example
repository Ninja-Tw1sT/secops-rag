# Copy this file to .env and fill in your values
# .env is gitignored and will never be committed

# === LLM Provider Selection ===
# Choose one: "ollama" (default, local), "groq" (cloud, fast), "openai" (cloud)
LLM_PROVIDER=ollama

# === Ollama (default LLM path, always used for embeddings) ===
OLLAMA_BASE_URL=http://localhost:11434
LLM_MODEL=llama3.1:8b
EMBEDDING_MODEL=nomic-embed-text
# Set to >0 if your GPU+driver works with Ollama. Default 0 (CPU) avoids
# Vulkan-backend token corruption on shared/weak GPUs.
LLM_NUM_GPU=0

# === Groq (only used if LLM_PROVIDER=groq) ===
# Free API key: https://console.groq.com
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-70b-versatile

# === OpenAI (only used if LLM_PROVIDER=openai) ===
# API key: https://platform.openai.com/api-keys
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# === Retrieval Tuning ===
CHUNK_SIZE=1000
CHUNK_OVERLAP=200
TOP_K=4

# === Paths ===
VECTOR_STORE_PATH=./vector_store
SOURCES_PATH=./data/sources
